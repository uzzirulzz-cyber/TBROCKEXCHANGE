# ============================================================
# Brock Exchange — Environment Variables (template)
# ============================================================
# Copy this file to .env and fill in your real values.
# DO NOT commit .env to git (it's already in .gitignore).
#
# Get your own credentials at:
#   - Postgres:  https://neon.tech  (free tier)
#   - MongoDB:   https://mongodb.com/atlas  (free tier)

# === Postgres (Neon) — REQUIRED ============================
# Use the POOLED connection string for DATABASE_URL (app runtime).
# Use the DIRECT connection string for DIRECT_URL (migrations / db:push).
# On Neon, both are shown in your project's "Connection Details".
# The pooled hostname has "-pooler" in it; the direct one does not.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.net/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.net/DBNAME?sslmode=require"

# === MongoDB (Atlas) — REQUIRED ============================
# Used by /api/market/history and /api/market/live for price caching.
MONGODB_URI="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=brockexchange"

# === Seed accounts (hardcoded, see src/lib/seed.ts) ========
# The seeder creates 1 Super Admin + 5 Sub-Agents with hardcoded credentials:
#   Super Admin:  crdbixx@gmail.com / 123playbeat
#   Sub-Agents:   subagentN@tradeN.com / default (forced to change on first login)
#   Invitation codes: PB-AG001 .. PB-AG005
# No env vars needed for seeding.

# === Setup steps (run after creating .env) =================
#   1. bun run db:push       # create all tables on your DB
#   2. bun run dev           # start dev server on :3000
#   3. curl -X POST http://localhost:3000/api/auth/seed
#   4. curl http://localhost:3000/api/health  # should show all ok: true
#   5. Open http://localhost:3000/?view=admin-login
#      Click "👑 Super Admin" — done.
